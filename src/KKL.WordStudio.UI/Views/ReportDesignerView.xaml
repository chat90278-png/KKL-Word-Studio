<UserControl x:Class="KKL.WordStudio.UI.Views.ReportDesignerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="ReportNodeTemplate" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" FontWeight="Medium" Margin="0,0,0,4"
                   Text="{Binding ActiveReportName, StringFormat='Report Designer — {0}', TargetNullValue='Report Designer (no active report)'}" />

        <!-- Add-element toolbar. Every button funnels through ReportDesignerViewModel.InsertElement,
             the same method a future drag-drop handler will call. -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Heading" Command="{Binding AddHeadingCommand}" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Add Alt Heading" Command="{Binding AddAltHeadingCommand}" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Add Table" Command="{Binding AddTableCommand}" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Add Header Text" Command="{Binding AddHeaderTextCommand}" Padding="8,4" Margin="0,0,8,0" />
            <Button Content="Add Footer Text" Command="{Binding AddFooterTextCommand}" Padding="8,4" Margin="0,0,12,0" />
            <CheckBox Content="Table of contents" IsChecked="{Binding IncludeTableOfContents}" VerticalAlignment="Center" />
        </StackPanel>

        <TreeView x:Name="Tree" ItemsSource="{Binding ReportTreeNodes}" ItemTemplate="{StaticResource ReportNodeTemplate}"
                  BorderThickness="0" SelectedItemChanged="Tree_SelectedItemChanged" />
    </DockPanel>
</UserControl>
