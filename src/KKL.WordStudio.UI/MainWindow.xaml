<Window x:Class="KKL.WordStudio.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KKL Word Studio"
        Width="1600" Height="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Surface}">

    <DockPanel LastChildFill="True">

        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Project" Command="{Binding NewProjectCommand}" />
                <MenuItem Header="_Save Project..." Command="{Binding SaveProjectCommand}" />
                <Separator />
                <MenuItem Header="_Export to Word..." Command="{Binding ExportToWordCommand}" />
                <Separator />
                <MenuItem Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Edit" />
            <MenuItem Header="_View" />
            <MenuItem Header="_Insert" />
            <MenuItem Header="_Help" />
        </Menu>

        <!-- Toolbar placeholder -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="New Project" Command="{Binding NewProjectCommand}" />
                <Button Content="Save Project" Command="{Binding SaveProjectCommand}" />
                <Separator />
                <Button Content="Export to Word" Command="{Binding ExportToWordCommand}" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusText}" />
        </StatusBar>

        <!-- Main workspace: four panels open simultaneously — Project Explorer,
             Excel Workspace, Report Designer, and (Table Properties + Preview)
             stacked on the right. Plain Grid + GridSplitters today; swappable
             for a docking framework later without ViewModel changes, since
             every panel only binds to its own ViewModel. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Project Explorer -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
                <ContentControl x:Name="ProjectExplorerHost" />
            </Border>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.Border}" />

            <!-- Excel Workspace -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,1,0">
                <ContentControl x:Name="ExcelWorkspaceHost" />
            </Border>
            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.Border}" />

            <!-- Report Designer -->
            <Border Grid.Column="4" Background="{DynamicResource Brush.Surface.Alt}">
                <ContentControl x:Name="ReportDesignerHost" />
            </Border>
            <GridSplitter Grid.Column="5" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.Border}" />

            <!-- Right column: Table Properties (top) + Preview (bottom) -->
            <Grid Grid.Column="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,0,0">
                    <ContentControl x:Name="TablePropertiesHost" />
                </Border>
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{DynamicResource Brush.Border}" />
                <Border Grid.Row="2" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,1,0,0">
                    <ContentControl x:Name="PreviewHost" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
