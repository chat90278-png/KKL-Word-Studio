<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Raw color values. Keys match KKL.WordStudio.Shared.Theming.ThemeKeys
         constants exactly, so C# code and XAML never drift apart. -->
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="Brush.Surface.Alt" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD0D0D0" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF0F6CBD" />
    <SolidColorBrush x:Key="Brush.Text.Primary" Color="#FF202020" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#FF6E6E6E" />

</ResourceDictionary>
